@import 'tailwindcss';
@import 'tw-animate-css';
@import 'shadcn-svelte/tailwind.css';

@import '@fontsource-variable/fredoka';
@import '@fontsource-variable/nunito-sans';
@import '@fontsource-variable/jetbrains-mono';

@custom-variant dark (&:is(.dark *));

:root {
	/* Fonts */
	--font-heading: 'Fredoka Variable', sans-serif;
	--font-sans: 'Nunito Sans Variable', sans-serif;
	--font-mono: 'JetBrains Mono Variable', monospace;

	/* Base */
	--background: oklch(0.98 0.006 220);
	--foreground: oklch(0.18 0.035 260);

	--card: oklch(0.96 0.01 220);
	--card-foreground: oklch(0.18 0.035 260);

	--popover: oklch(0.98 0.006 220);
	--popover-foreground: oklch(0.18 0.035 260);

	/* Brand colors */
	--primary: oklch(0.61 0.205 269);
	--primary-foreground: oklch(0.98 0.006 220);

	--secondary: oklch(0.825 0.144 213);
	--secondary-foreground: oklch(0.16 0.035 260);

	--accent: oklch(0.588 0.283 305);
	--accent-foreground: oklch(0.98 0.006 220);

	--muted: oklch(0.92 0.018 235);
	--muted-foreground: oklch(20.075% 0.03025 263.555);

	--destructive: oklch(0.58 0.22 27);
	--destructive-foreground: oklch(0.98 0.006 220);

	--border: oklch(0.86 0.025 245);
	--input: oklch(0.86 0.025 245);
	--ring: oklch(0.61 0.205 269);

	/* Charts */
	--chart-1: oklch(0.825 0.144 213);
	--chart-2: oklch(0.61 0.205 269);
	--chart-3: oklch(0.588 0.283 305);
	--chart-4: oklch(0.697 0.171 245);
	--chart-5: oklch(0.72 0.2 300);

	/* Radius */
	--radius: 0.9rem;

	/* Sidebar */
	--sidebar: oklch(0.95 0.012 230);
	--sidebar-foreground: oklch(0.18 0.035 260);
	--sidebar-primary: oklch(0.61 0.205 269);
	--sidebar-primary-foreground: oklch(0.98 0.006 220);
	--sidebar-accent: oklch(0.92 0.018 235);
	--sidebar-accent-foreground: oklch(0.18 0.035 260);
	--sidebar-border: oklch(0.86 0.025 245);
	--sidebar-ring: oklch(0.61 0.205 269);

	/* 3D Duolingo-like shadow tokens */
	--shadow-3d: oklch(0.8 0.03 245);
	--shadow-3d-primary: oklch(0.42 0.16 269);
	--shadow-3d-secondary: oklch(0.62 0.13 213);
	--shadow-3d-accent: oklch(0.42 0.21 305);
	--shadow-3d-destructive: oklch(0.44 0.17 27);
}

.dark {
	--background: oklch(0.13 0.03 260);
	--foreground: oklch(0.94 0.018 230);

	--card: oklch(0.17 0.035 260);
	--card-foreground: oklch(0.94 0.018 230);

	--popover: oklch(0.17 0.035 260);
	--popover-foreground: oklch(0.94 0.018 230);

	--primary: oklch(0.825 0.144 213);
	--primary-foreground: oklch(0.13 0.03 260);

