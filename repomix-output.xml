  channel         ReminderChannel   @default(admin_notification)
  createdBy       ReminderCreatedBy @default(system) @map("created_by")
  sentAt          DateTime?         @map("sent_at")
  completedAt     DateTime?         @map("completed_at")
  metadata        Json              @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  business        Business          @relation(fields: [businessId], references: [id])
  customer        Customer?         @relation(fields: [customerId], references: [id])
  conversation    Conversation?     @relation(fields: [conversationId], references: [id])
  reservation     Reservation?      @relation(fields: [reservationId], references: [id])
  order           Order?            @relation(fields: [orderId], references: [id])

  @@index([businessId])
  @@index([businessId, scheduledAt])
  @@index([businessId, status])
  @@index([customerId])
  @@index([reservationId])
  @@index([orderId])
  @@map("reminders")
}

model Integration {
  id                    String              @id @default(uuid()) @db.Uuid
  businessId            String              @map("business_id") @db.Uuid
  provider              IntegrationProvider
  status                IntegrationStatus   @default(disconnected)
  accessTokenEncrypted  String?             @map("access_token_encrypted")
  refreshTokenEncrypted String?             @map("refresh_token_encrypted")
  expiresAt             DateTime?           @map("expires_at")
  metadata              Json                @default("{}")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  business              Business            @relation(fields: [businessId], references: [id])
  spreadsheetConfigs    SpreadsheetConfig[]

  @@index([businessId])
  @@index([businessId, provider])
  @@map("integrations")
}

model SpreadsheetConfig {
  id                     String      @id @default(uuid()) @db.Uuid
  businessId             String      @map("business_id") @db.Uuid
  integrationId          String      @map("integration_id") @db.Uuid
  spreadsheetId          String      @map("spreadsheet_id")
  spreadsheetUrl         String?     @map("spreadsheet_url")
  customersSheetName     String      @default("Customers") @map("customers_sheet_name")
  reservationsSheetName  String      @default("Reservations") @map("reservations_sheet_name")
  ordersSheetName        String      @default("Orders") @map("orders_sheet_name")
  remindersSheetName     String      @default("Reminders") @map("reminders_sheet_name")
  syncCustomers          Boolean     @default(true) @map("sync_customers")
  syncOrders             Boolean     @default(true) @map("sync_orders")
  syncReservations       Boolean     @default(true) @map("sync_reservations")
  syncReminders          Boolean     @default(false) @map("sync_reminders")
  autoSyncEnabled        Boolean     @default(false) @map("auto_sync_enabled")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  business               Business    @relation(fields: [businessId], references: [id])
  integration            Integration @relation(fields: [integrationId], references: [id])
  syncLogs               SpreadsheetSyncLog[]

  @@map("spreadsheet_configs")
}

model SpreadsheetSyncLog {
  id                   String            @id @default(uuid()) @db.Uuid
  businessId           String            @map("business_id") @db.Uuid
  spreadsheetConfigId  String            @map("spreadsheet_config_id") @db.Uuid
  entityType           String            @map("entity_type")
  entityId             String?           @map("entity_id") @db.Uuid
  status               SyncStatus        @default(pending)
  errorMessage         String?           @map("error_message")
  syncedAt             DateTime?         @map("synced_at")
  createdAt            DateTime          @default(now()) @map("created_at")

  business             Business          @relation(fields: [businessId], references: [id])
  spreadsheetConfig    SpreadsheetConfig @relation(fields: [spreadsheetConfigId], references: [id])

  @@map("spreadsheet_sync_logs")
}

model HumanHandoff {
  id               String        @id @default(uuid()) @db.Uuid
  businessId       String        @map("business_id") @db.Uuid
  conversationId   String        @map("conversation_id") @db.Uuid
  customerId       String        @map("customer_id") @db.Uuid
  reason           HandoffReason
  summary          String?
  status           HandoffStatus @default(open)
  assignedUserId   String?       @map("assigned_user_id") @db.Uuid
  resolvedAt       DateTime?     @map("resolved_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  business         Business      @relation(fields: [businessId], references: [id])
  conversation     Conversation  @relation(fields: [conversationId], references: [id])
  customer         Customer      @relation(fields: [customerId], references: [id])
  assignedUser     User?         @relation("AssignedHandoffs", fields: [assignedUserId], references: [id])

  @@map("human_handoffs")
}

model AgentRun {
  id              String         @id @default(uuid()) @db.Uuid
  businessId      String         @map("business_id") @db.Uuid
  conversationId  String?        @map("conversation_id") @db.Uuid
  customerId      String?        @map("customer_id") @db.Uuid
  agentType       AgentType      @map("agent_type")
  input           String?
  output          String?
  intent          String?
  status          AgentRunStatus @default(running)
  errorMessage    String?        @map("error_message")
  tokensInput     Int            @default(0) @map("tokens_input")
  tokensOutput    Int            @default(0) @map("tokens_output")
  latencyMs       Int?           @map("latency_ms")
  metadata        Json           @default("{}")
  createdAt       DateTime       @default(now()) @map("created_at")
  completedAt     DateTime?      @map("completed_at")

  business        Business       @relation(fields: [businessId], references: [id])
  conversation    Conversation?  @relation(fields: [conversationId], references: [id])
  customer        Customer?      @relation(fields: [customerId], references: [id])
  toolExecutions  ToolExecution[]

  @@index([businessId])
  @@index([conversationId])
  @@index([customerId])
  @@index([agentType])
  @@index([createdAt])
  @@map("agent_runs")
}

model ToolExecution {
  id              String               @id @default(uuid()) @db.Uuid
  businessId      String               @map("business_id") @db.Uuid
  agentRunId      String?              @map("agent_run_id") @db.Uuid
  conversationId  String?              @map("conversation_id") @db.Uuid
  toolName        String               @map("tool_name")
  input           Json                 @default("{}")
  output          Json                 @default("{}")
  status          ToolExecutionStatus  @default(running)
  errorMessage    String?              @map("error_message")
  latencyMs       Int?                 @map("latency_ms")
  createdAt       DateTime             @default(now()) @map("created_at")
  completedAt     DateTime?            @map("completed_at")

  business        Business             @relation(fields: [businessId], references: [id])
  agentRun        AgentRun?            @relation(fields: [agentRunId], references: [id])
  conversation    Conversation?        @relation(fields: [conversationId], references: [id])

  @@map("tool_executions")
}

model Notification {
  id           String           @id @default(uuid()) @db.Uuid
  businessId   String           @map("business_id") @db.Uuid
  userId       String?          @map("user_id") @db.Uuid
  type         NotificationType
  title        String
  message      String?
  isRead       Boolean          @default(false) @map("is_read")
  metadata     Json             @default("{}")
  createdAt    DateTime         @default(now()) @map("created_at")
  readAt       DateTime?        @map("read_at")

  business     Business         @relation(fields: [businessId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id           String    @id @default(uuid()) @db.Uuid
  businessId   String?   @map("business_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  action       String
  entityType   String    @map("entity_type")
  entityId     String?   @map("entity_id") @db.Uuid
  oldData      Json?     @map("old_data")
  newData      Json?     @map("new_data")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  business     Business? @relation(fields: [businessId], references: [id])
  user         User?     @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model File {
  id               String    @id @default(uuid()) @db.Uuid
  businessId       String    @map("business_id") @db.Uuid
  uploadedBy       String?   @map("uploaded_by") @db.Uuid
  filename         String
  originalName     String    @map("original_name")
  mimeType         String    @map("mime_type")
  sizeBytes        Int       @map("size_bytes")
  storageProvider  String    @default("local") @map("storage_provider")
  storagePath      String    @map("storage_path")
  publicUrl        String?   @map("public_url")
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at")

  business         Business  @relation(fields: [businessId], references: [id])
  uploader         User?     @relation(fields: [uploadedBy], references: [id])
  knowledgeDocs    KnowledgeDocument[]

  @@map("files")
}

model WebhookEvent {
  id           String             @id @default(uuid()) @db.Uuid
  businessId   String?            @map("business_id") @db.Uuid
  provider     String
  eventType    String             @map("event_type")
  externalId   String?            @map("external_id")
  payload      Json
  status       WebhookEventStatus @default(received)
  processedAt  DateTime?          @map("processed_at")
  errorMessage String?            @map("error_message")
  createdAt    DateTime           @default(now()) @map("created_at")

  business     Business?          @relation(fields: [businessId], references: [id])

  @@index([provider, externalId])
  @@map("webhook_events")
}

model CronJob {
  id           String        @id @default(uuid()) @db.Uuid
  jobName      String        @map("job_name")
  status       CronJobStatus @default(running)
  startedAt    DateTime      @map("started_at")
  finishedAt   DateTime?     @map("finished_at")
  result       Json          @default("{}")
  errorMessage String?       @map("error_message")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("cron_jobs")
}

model Payment {
  id                   String          @id @default(uuid()) @db.Uuid
  businessId           String          @map("business_id") @db.Uuid
  orderId              String?         @map("order_id") @db.Uuid
  reservationId        String?         @map("reservation_id") @db.Uuid
  customerId           String?         @map("customer_id") @db.Uuid
  conversationId       String?         @map("conversation_id") @db.Uuid
  provider             PaymentProvider @default(manual)
  method               PaymentMethod   @default(manual)
  status               PaymentStatus   @default(unpaid)
  amount               Int
  currency             String          @default("IDR")
  merchantReferenceNo  String          @unique @map("merchant_reference_no")
  providerReferenceNo  String?         @map("provider_reference_no")
  qrContent            String?         @map("qr_content")
  qrImageUrl           String?         @map("qr_image_url")
  expiresAt            DateTime?       @map("expires_at")
  paidAt               DateTime?       @map("paid_at")
  rawRequest           Json?           @map("raw_request")
  rawResponse          Json?           @map("raw_response")
  rawCallback          Json?           @map("raw_callback")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  business             Business        @relation(fields: [businessId], references: [id])
  order                Order?          @relation(fields: [orderId], references: [id])
  reservation          Reservation?    @relation(fields: [reservationId], references: [id])
  customer             Customer?       @relation(fields: [customerId], references: [id])
  conversation         Conversation?   @relation(fields: [conversationId], references: [id])
  events               PaymentEvent[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([orderId])
  @@index([reservationId])
  @@index([merchantReferenceNo])
  @@map("payments")
}

model PaymentEvent {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  paymentId   String   @map("payment_id") @db.Uuid
  eventType   String   @map("event_type")
  payload     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  business    Business @relation(fields: [businessId], references: [id])
  payment     Payment  @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([businessId])
  @@map("payment_events")
}
