# ─────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────
# MYSQL
# Internal hostname: mysql (Docker service name)
# ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=nongki_db
MYSQL_USER=nongki_user
MYSQL_PASSWORD=nongki_pass

# Full DSN used by api service — hostname must be "mysql" (Docker internal)
DATABASE_URL=mysql://nongki_user:nongki_pass@mysql:3306/nongki_db

# ─────────────────────────────────────────
# REDIS
# Internal hostname: redis (Docker service name)
# ─────────────────────────────────────────
REDIS_PASSWORD=redispassword

# Used by api, wa-worker, ai-engine — hostname must be "redis"
REDIS_URL=redis://:redispassword@redis:6379

# ─────────────────────────────────────────
# RABBITMQ
# Internal hostname: rabbitmq (Docker service name)
# ─────────────────────────────────────────
RABBITMQ_DEFAULT_USER=nongki_rabbit
RABBITMQ_DEFAULT_PASS=rabbitpassword

# Used by api, wa-worker, ai-engine — hostname must be "rabbitmq"
RABBITMQ_URL=amqp://nongki_rabbit:rabbitpassword@rabbitmq:5672

# Management UI port (only exposed in dev profile)
RABBITMQ_MANAGEMENT_PORT=15672

# ─────────────────────────────────────────
# API SERVICE (Fastify)
# Internal hostname: api (Docker service name)
# ─────────────────────────────────────────
API_PORT=4000
JWT_SECRET=your_jwt_secret_here_change_in_production

# ─────────────────────────────────────────
# WA-WORKER SERVICE (Baileys)
# Internal hostname: wa-worker (Docker service name)
# Communicates with api internally via Docker network
# ─────────────────────────────────────────
WA_WORKER_PORT=5000

# wa-worker calls api using internal Docker hostname "api"
API_INTERNAL_URL=http://api:4000/api/v1

# ─────────────────────────────────────────
# AI-ENGINE SERVICE (Python/LangChain)
# Internal hostname: ai-engine (Docker service name)
# ─────────────────────────────────────────
AI_ENGINE_PORT=8000

# LLM provider keys (use one or both)
OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=your-groq-key-here

# FAISS vector store path inside container (mapped to named volume faiss_data)
FAISS_PATH=/app/vector_store

# SQLite database path inside container (mapped to named volume sqlite_data)
SQLITE_PATH=/app/db/ai.db

# ai-engine calls api using internal Docker hostname "api"
API_INTERNAL_URL=http://api:4000/api/v1

# ─────────────────────────────────────────
# WEB (SvelteKit)
# Internal hostname: web (Docker service name)
# PUBLIC_ prefix = exposed to browser (Vite/SvelteKit convention)
# ─────────────────────────────────────────
WEB_PORT=3000

# This is browser-facing — goes through nginx, uses public path
PUBLIC_API_URL=http://localhost/api/v1

# SSR server-side calls from web container to api container (internal)
API_SSR_URL=http://api:4000/api/v1


NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
