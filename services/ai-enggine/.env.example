APP_ENV=development
APP_NAME=ningki-ai-enggine
APP_PORT=8000

API_BASE_URL=http://localhost:3000
API_INTERNAL_TOKEN=change_me

GEMINI_API_KEY=change_me
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

FAISS_INDEX_DIR=./app/storage/faiss
UPLOAD_TMP_DIR=./app/storage/tmp

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379
RABBITMQ_URL=amqp://nongki:change-me@rabbitmq:5672
RABBITMQ_DEFAULT_USER=nongki
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_MANAGEMENT_PORT=15673
EVENT_EXCHANGE=nongki.events
EVENT_EXCHANGE_TYPE=topic
EVENT_PRODUCER_AI=services/ai-engine

LOG_LEVEL=info
