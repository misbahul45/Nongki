# =========================================================
# SERVICES/API ENV EXAMPLE
# API membaca root .env dari ../../.env
# File ini hanya dokumentasi subset env untuk services/api
# =========================================================

NODE_ENV=development
API_PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ningki?schema=public

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
COOKIE_SECRET=change_me
SESSION_SECRET=change_me

API_INTERNAL_TOKEN=change_me_internal_token

AI_ENGINE_URL=http://localhost:8000
WA_WORKER_URL=http://localhost:4000

CORS_ORIGIN=http://localhost:5173

FILE_STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
PUBLIC_FILE_BASE_URL=http://localhost:3000/files

ENCRYPTION_KEY=change_me_32_chars_minimum

REDIS_URL=redis://localhost:6379

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/google/callback

ASTRAPAY_CLIENT_ID=
ASTRAPAY_CLIENT_SECRET=
ASTRAPAY_PRIVATE_KEY=
ASTRAPAY_PUBLIC_KEY=
ASTRAPAY_MERCHANT_ID=
ASTRAPAY_BASE_URL=
ASTRAPAY_CALLBACK_URL=http://localhost:3000/webhooks/astrapay

LOG_LEVEL=info
