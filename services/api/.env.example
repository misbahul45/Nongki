# =========================================================
# SERVICES/API ENV EXAMPLE
# API membaca root .env dari ../../.env
# File ini hanya dokumentasi subset env untuk services/api
# =========================================================

NODE_ENV=development
API_PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://nongki:change-me@postgres:5432/nongki?schema=public

JWT_ACCESS_SECRET=replace_with_access_token_secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
COOKIE_SECRET=replace_with_cookie_secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
BCRYPT_SALT_ROUNDS=12

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me

API_INTERNAL_TOKEN=change-me

AI_ENGINE_URL=http://localhost:8000
WA_WORKER_URL=http://localhost:4000

CORS_ORIGIN=http://localhost:5173

FILE_STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
PUBLIC_FILE_BASE_URL=http://localhost:3000/files

ENCRYPTION_KEY=change-me-32-chars-minimum

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379

RABBITMQ_DEFAULT_USER=nongki
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_URL=amqp://nongki:change-me@rabbitmq:5672
RABBITMQ_MANAGEMENT_PORT=15673

AUTH_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_IP_LIMIT=20
AUTH_LOGIN_EMAIL_LIMIT=5
AUTH_REGISTER_IP_LIMIT=10
AUTH_REGISTER_EMAIL_LIMIT=3
AUTH_REFRESH_IP_LIMIT=60

EVENT_BUS_ENABLED=true
EVENT_EXCHANGE=nongki.events
EVENT_EXCHANGE_TYPE=topic
EVENT_PRODUCER_API=services/api
EVENT_PRODUCER_WA=services/wa-worker
EVENT_PRODUCER_AI=services/ai-engine

AUTH_ME_CACHE_TTL_SECONDS=60
REFRESH_FAMILY_COMPROMISED_TTL_DAYS=7

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/google/callback

ASTRAPAY_CLIENT_ID=
ASTRAPAY_CLIENT_SECRET=
ASTRAPAY_PRIVATE_KEY=
ASTRAPAY_PUBLIC_KEY=
ASTRAPAY_MERCHANT_ID=
ASTRAPAY_BASE_URL=
ASTRAPAY_CALLBACK_URL=http://localhost:3000/webhooks/astrapay

LOG_LEVEL=info
