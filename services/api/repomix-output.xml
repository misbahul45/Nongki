  await app.close();
});

describe("GET /health", () => {
  it("should return 200 and ok status", async () => {
    const res = await request(app.server)
      .get("/health")
      .expect(200);

    expect(res.body.status).toBe("ok");
    expect(res.body.service).toBe("nongki-api");
  });
});
